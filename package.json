{
  "name": "pick-it-up",
  "version": "0.1.0",
  "description": "PIU song database builder & CBPIU song list manager",
  "type": "module",
  "scripts": {
    "scrape": "node scraper/index.js",
    "scrape:details": "node scraper/index.js --details",
    "scrape:resume": "node scraper/index.js --resume",
    "merge": "node scraper/merge.js",
    "merge:apply": "node scraper/merge.js --apply",
    "fill-artists": "node scraper/fill-song-artists.js",
    "fill-artists:apply": "node scraper/fill-song-artists.js --apply",
    "fill-step-artists": "node scraper/fill-step-artists.js",
    "fill-step-artists:apply": "node scraper/fill-step-artists.js --apply",
    "fill-step-artists:batch": "node scraper/fill-step-artists.js --apply --limit 90",
    "split-modes": "node scraper/split-mixed-modes.js",
    "split-modes:apply": "node scraper/split-mixed-modes.js --apply",
    "serve": "npx serve . -l 3000"
  },
  "dependencies": {
    "playwright": "^1.44.0"
  }
}
